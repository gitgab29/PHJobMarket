# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=phjobmarket
POSTGRES_USER=phjobmarket
POSTGRES_PASSWORD=change_me

# ─── Django API ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-generate-with-python-secrets
DEBUG=true
DB_HOST=localhost
DB_PORT=5432
DB_USER=phjobmarket
DB_PASSWORD=change_me
DB_NAME=phjobmarket
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://phjobmarket:change_me@postgres:5432/phjobmarket
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__FERNET_KEY=change-me-generate-with-cryptography-fernet

# ─── Reddit API (for salary thread scraper) ───────────────────────────────────
# Get credentials at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PHJobMarket/1.0 by your_reddit_username

# ─── Facebook (for FB Job Group scraper) ──────────────────────────────────────
# Use a dedicated burner account; store cookies after manual login
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=
FACEBOOK_COOKIES_PATH=./scrapers/cookies/fb_cookies.json

# ─── Proxy (optional rotation) ────────────────────────────────────────────────
# Comma-separated list of proxy URLs
PROXY_LIST=
PROXY_ENABLED=false

# ─── dbt ──────────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=./dbt_transform
DBT_TARGET=dev
