# Production environment for docker-compose.prod.yml
# Copy to .env.prod on the server and fill in real values. DO NOT commit .env.prod.
#
#   cp .env.prod.example .env.prod && chmod 600 .env.prod
#
# Generate a secret key:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"

# ─── Django ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-50-char-random-secret
DEBUG=False
# Comma-separated. Use your EC2 Elastic IP and/or domain (no scheme, no port).
ALLOWED_HOSTS=your-elastic-ip,your-domain.com
# Same-origin in production (nginx serves the frontend), so CORS is usually
# unnecessary — set it only if a different origin must call the API.
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Flip these ON in Phase 4, once HTTPS is actually terminating in front of nginx.
# Leaving them False keeps the http://localhost smoke test working.
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# ─── Database (Postgres in Docker on the box) ──────────────────────────────
DB_NAME=phjobmarket
DB_USER=phjobmarket
DB_PASSWORD=replace-with-a-strong-db-password
# DB_HOST / DB_PORT are set by docker-compose.prod.yml (postgres:5432) — leave them out here.
